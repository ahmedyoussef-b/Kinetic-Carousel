# Firebase Admin SDK Configuration
# ----------------------------------
# This is a server-side-only variable. It should NOT be prefixed with NEXT_PUBLIC_.
# 1. Go to your Firebase project settings -> Service accounts.
# 2. Click "Generate new private key".
# 3. A JSON file will be downloaded.
# 4. Copy the ENTIRE content of that JSON file and paste it here, enclosed in single quotes.
# IMPORTANT: It must be a single line.
FIREBASE_ADMIN_SDK_CONFIG='PASTE_YOUR_FIREBASE_ADMIN_SDK_JSON_HERE'

# Firebase Client SDK Configuration
# ---------------------------------
# These are public variables and are safe to expose to the browser.
# Find these values in your Firebase project settings -> General -> Your apps -> Firebase SDK snippet -> Config.
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Cloudinary (Optional - for image uploads)
# ----------------------------------------
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
